generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  SALES
}

enum OrderStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum InventoryStatus {
  AVAILABLE
  CONSIGNED
  SOLD
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR_CODE
}

model User {
  id       String @id @default(uuid())
  fullName String
  email    String @unique
  password String

  role UserRole @default(SALES)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String  @id @default(uuid())
  fullName    String
  phoneNumber String
  email       String?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(uuid())

  sku         String @unique
  productCode String @unique

  name String

  description String?

  category String

  productType String

  material String

  gemstone String?

  weight Float?

  size String?

  imageUrl String?

  price Decimal @db.Decimal(12, 2)

  stock Int @default(1)

  status InventoryStatus @default(AVAILABLE)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
  @@index([productCode])
  @@index([name])
  @@index([category])
  @@index([status])
}

model Order {
  id String @id @default(uuid())

  customerId String

  customer Customer @relation(fields: [customerId], references: [id])

  totalAmount Decimal @db.Decimal(12, 2)

  paidAmount Decimal @default(0) @db.Decimal(12, 2)

  remainingAmount Decimal @db.Decimal(12, 2)

  status OrderStatus @default(PENDING)

  isConsignment Boolean @default(false)

  items OrderItem[]

  payments Payment[]

  sale Sale?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String

  productId String

  quantity Int

  price Decimal @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id])

  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id String @id @default(uuid())

  orderId String

  amount Decimal @db.Decimal(12, 2)

  paymentMethod PaymentMethod

  slipUrl String?

  note String?

  paymentDate DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

model Sale {
  id String @id @default(uuid())

  orderId String @unique

  order Order @relation(fields: [orderId], references: [id])

  soldAt DateTime @default(now())
}
